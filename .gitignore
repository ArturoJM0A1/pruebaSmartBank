# SmartBank - Git Ignore
# Archivos que nunca deben subirse al repositorio

# Dependencias
node_modules/
bower_components/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.cache/

# Coverage & Testing
coverage/
.nyc_output/
*.lcov

# Environment variables (NUNCA subir credenciales)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# SonarQube
.sonar/
.scannerwork/

# Temporary files
tmp/
temp/
*.tmp

# Optional: compiled TypeScript (if added later)
*.tsbuildinfo

# Distribution packages
*.tar.gz
*.rar
*.zip
